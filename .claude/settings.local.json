{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-git.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-pip.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git rev-parse:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run python:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(curl:*)",
      "Bash(GIT_EDITOR=true git diff:*)",
      "Bash(GIT_EDITOR=true git status:*)",
      "Bash(GIT_EDITOR=true git log:*)",
      "Bash(ls:*)",
      "WebFetch(domain:docs.primeintellect.ai)",
      "WebFetch(domain:www.primeintellect.ai)",
      "Bash(ssh:*)"
    ]
  }
}
